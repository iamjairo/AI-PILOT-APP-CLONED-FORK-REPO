# AI-Pilot macOS code-signing + notarization secrets.
# Copy to `.env.signing` (git-ignored) and fill in. NEVER commit real values.
# Load before building:  set -a; source .env.signing; set +a; npm run build:mac
#
# From your Apple Developer account:
#  1. Export your "Developer ID Application" cert as a .p12, then:
#       base64 -i DeveloperID.p12 | pbcopy      # → CSC_LINK
CSC_LINK=
CSC_KEY_PASSWORD=
#  2. Apple account + app-specific password (https://appleid.apple.com → Sign-In & Security → App-Specific Passwords)
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
#  3. Your Apple Team ID
APPLE_TEAM_ID=
